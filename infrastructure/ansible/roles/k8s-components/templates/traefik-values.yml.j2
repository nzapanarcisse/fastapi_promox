###############################################################################
# Traefik Helm Values - Configuration pour Gateway API + Cert-Manager
# NOTE : certResolvers a été supprimé dans le chart Traefik v33+
#        Les certificats TLS sont gérés par Cert-Manager (pas par Traefik)
###############################################################################

# Utilisation de Traefik v3 avec support Gateway API
image:
  tag: "{{ traefik_version }}"

# Activation du Gateway API provider
providers:
  kubernetesGateway:
    enabled: true
  kubernetesCRD:
    enabled: true
  kubernetesIngress:
    enabled: true

# Points d'entrée
ports:
  web:
    port: 8000
    exposedPort: 80
    protocol: TCP
    # Redirection HTTP → HTTPS
    redirectTo:
      port: websecure
  websecure:
    port: 8443
    exposedPort: 443
    protocol: TCP
    tls:
      enabled: true
      # Pas de certResolver ici — Cert-Manager gère les certificats
      # via des ressources Certificate/ClusterIssuer dans Kubernetes

# Service de type NodePort (pas de LoadBalancer sur bare-metal/Proxmox)
service:
  type: NodePort
  spec:
    externalTrafficPolicy: Local

# Activation du dashboard Traefik
ingressRoute:
  dashboard:
    enabled: true
    matchRule: Host(`traefik.{{ domain }}`)
    entryPoints:
      - websecure

# Logs
logs:
  general:
    level: INFO
  access:
    enabled: true

# Ressources
resources:
  requests:
    cpu: "100m"
    memory: "128Mi"
  limits:
    cpu: "500m"
    memory: "512Mi"

# Tolérations pour s'exécuter sur tous les noeuds si nécessaire
tolerations: []

# Node selector
nodeSelector: {}

# Nombre de réplicas
deployment:
  replicas: 2

# Pod disruption budget
podDisruptionBudget:
  enabled: true
  minAvailable: 1
